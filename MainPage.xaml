<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAccessibilityRepro.MainPage"
             Title="Home">

    <VerticalStackLayout Padding="30" Spacing="20">
        <Label Text="MAUI 10.0.70 Accessibility Crash Repro"
               FontSize="18"
               FontAttributes="Bold" />
        <Label Text="Steps to reproduce:&#10;1. Enable Voice Access via adb&#10;2. Tap the button below&#10;3. App crashes with MissingMethodException on AccessibilityNodeInfoCompat.set_Checked" />
        <Button Text="Navigate to CollectionView page"
                Clicked="OnNavigateClicked" />
    </VerticalStackLayout>

</ContentPage>
